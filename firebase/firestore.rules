rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollections: receipts, rewards, carMiles, shoppingList, paymentOptions, shoppingFrequency
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Receipt items nested under receipts
        match /items/{itemId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Admin view (populated by Cloud Functions with admin SDK)
    match /admin_receipts/{docId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
