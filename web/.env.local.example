# Copy this file to .env.local and fill in your Supabase project values
# Found in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: for server-side admin operations (keep secret)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# AI receipt parser — Groq (free tier, no card required, recommended)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Optional model overrides
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional alternative parsers (leave blank unless using)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: OpenAI for AI spending insights
OPENAI_API_KEY=sk-...

# ── Cross-instance rate limiting (Upstash Redis) ─────────────────────────
# Without these, lib/apiGuard.js falls back to a per-Vercel-instance Map.
# That's fine for local dev. In production it's INEFFECTIVE: Vercel auto-
# scales function instances and each has its own Map, so the rate limits
# can be defeated by sending enough concurrent traffic to spin up multiple
# instances (verified at N=100 concurrent sign-ups from one IP).
#
# Setup:
#   1. Create a Redis database at https://console.upstash.com/redis
#   2. Pick a region near your Vercel deployment region (default is iad-1)
#   3. Copy the REST URL + REST token (Upstash dashboard → REST API tab)
#   4. Add both env vars here AND in Vercel Project Settings → Environment Variables
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
